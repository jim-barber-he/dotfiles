# This is the configuration file for Ghostty.
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.

auto-update = off

# All but the first surface (see initial-command below) will run this command.
command = direct:/bin/zsh

# I don't want to use the mouse to move the cursor.
cursor-click-to-move = false

# Chooses the first font and if a character is not available, it falls through to the next in the list.
font-family = Hack Nerd Font Mono
font-family = DejaVuSansM Nerd Font Mono
font-family = Noto Color Emoji

font-size = 11

# Run a login shell for the first ghostty surface that is opened.
initial-command = direct:/bin/zsh -l

# ghostty +list-keybinds
# Actions: ghostty +list-actions
keybind = ctrl+shift+enter=new_split:auto
keybind = ctrl+shift+x=toggle_split_zoom
keybind = ctrl+shift+z=jump_to_prompt:-1
keybind = ctrl+shift+tab=goto_split:previous
keybind = ctrl+tab=goto_split:next

# Disable smart selection of URLs since it screws up double-click selection when slashes are in the string.
link-url = false

# scrollback buffer in bytes. Always kept in memory.
scrollback-limit = 100000000

# Don't clear the selection when typing. Can still clear with a mouse-click or pressing Esc.
selection-clear-on-typing = false

# Default: selection-word-chars = " \t'\"│`|:;,()[]{}<>$"
selection-word-chars = " \t'\"│`|:;,()[]{}<>$!#%&*+-./=?@\\^~☸🔒"

shell-integration-features = cursor,path,ssh-env,ssh-terminfo,no-sudo,title

# Themes: ghostty +list-themes
#
# I like the `Kitty Default` theme, but with the following changes:
# - a foreground that is less bright
# - make dull yellow more orange as per the standard xterm color scheme.
# - different selection colors.
#
foreground = #aaaaaa
palette = 3=#c47e00
selection-background = #606060
selection-foreground = #ffffff
theme = Kitty Default

# Don't dim unfocused splits.
unfocused-split-opacity = 1

# Hide title bar
window-decoration = none

# Hide the tab bar
window-show-tab-bar = never

# Read configuration specific to this host.
config-file = ?config.local
